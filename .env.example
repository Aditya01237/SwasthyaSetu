POSTGRES_USER=myuser
POSTGRES_PASSWORD=myuser
POSTGRES_DB=swasthyasetudb
POSTGRES_PORT=5432

BACKEND_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swasthyasetudb
AUTH_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swasthyasetudb
PATIENT_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swasthyasetudb
APPOINTMENT_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swasthyasetudb
HOSPITAL_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swasthyasetudb

# For the service-owned DB test profile, use docker-compose.service-dbs.yml.
# AUTH_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/auth_db
# PATIENT_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/patient_db
# APPOINTMENT_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/appointment_db
# HOSPITAL_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/hospital_db

REDIS_PORT=6379

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

APP_EVENTS_EXCHANGE=swasthya.events
APP_EVENTS_APPOINTMENT_BOOKED_ROUTING_KEY=appointment.booked
APP_EVENTS_PATIENT_REGISTERED_ROUTING_KEY=patient.registered
APP_EVENTS_OTP_REQUESTED_ROUTING_KEY=auth.otp-requested
APP_EVENTS_DOCTOR_REGISTERED_ROUTING_KEY=doctor.registered
APP_EVENTS_HOSPITAL_UPSERTED_ROUTING_KEY=hospital.upserted
APP_EVENTS_APPOINTMENT_BOOKED_QUEUE=notification.appointment-booked
APP_EVENTS_PATIENT_REGISTERED_QUEUE=notification.patient-registered
APP_EVENTS_OTP_REQUESTED_QUEUE=notification.otp-requested
APP_EVENTS_AUTH_PATIENT_REGISTERED_QUEUE=auth.patient-registered
APP_EVENTS_AUTH_HOSPITAL_UPSERTED_QUEUE=auth.hospital-upserted
APP_EVENTS_AUTH_DOCTOR_REGISTERED_QUEUE=auth.doctor-registered
APP_EVENTS_APPOINTMENT_PATIENT_REGISTERED_QUEUE=appointment.patient-registered
APP_EVENTS_APPOINTMENT_HOSPITAL_UPSERTED_QUEUE=appointment.hospital-upserted
APP_EVENTS_APPOINTMENT_DOCTOR_REGISTERED_QUEUE=appointment.doctor-registered
APP_EVENTS_PATIENT_APPOINTMENT_BOOKED_QUEUE=patient.appointment-booked
APP_EVENTS_PATIENT_HOSPITAL_UPSERTED_QUEUE=patient.hospital-upserted
APP_EVENTS_PATIENT_DOCTOR_REGISTERED_QUEUE=patient.doctor-registered
APP_EVENTS_HOSPITAL_DOCTOR_REGISTERED_QUEUE=hospital.doctor-registered

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
PATIENT_SERVICE_PORT=8082
APPOINTMENT_SERVICE_PORT=8083
HOSPITAL_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8086
BACKEND_PORT=8090
AI_SERVICE_PORT=8000
PATIENT_FRONTEND_PORT=5173
DOCTOR_FRONTEND_PORT=5174

ELASTIC_VERSION=8.15.3
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
LOGSTASH_GELF_PORT=12201
LOGSTASH_API_PORT=9600
LOGSTASH_JAVA_OPTS=-Xms256m -Xmx256m
KIBANA_PORT=5601

IMAGE_REPOSITORY_PREFIX=ghcr.io/aditya01237/swasthya-setu
IMAGE_TAG=local

# ─── SMTP (backend + notification-service) ─────────────────────────────────
# Use Gmail (or another real provider) for OTP and notification emails in Docker.
# Use an App Password for Gmail: https://support.google.com/accounts/answer/185833
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
# Optional: override From header (defaults to SPRING_MAIL_USERNAME inside notification-service).
# APP_NOTIFICATION_FROM=your@gmail.com

# Local-only: capture mail in Mailpit instead of Gmail — set these and use NOTIFICATION_* overrides below.
# SPRING_MAIL_HOST=mailpit
# SPRING_MAIL_PORT=1025
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
# NOTIFICATION_MAIL_HOST=mailpit
# NOTIFICATION_MAIL_PORT=1025
# NOTIFICATION_MAIL_SMTP_AUTH=false
# NOTIFICATION_MAIL_SMTP_STARTTLS=false

JWT_SECRET=change-me-to-at-least-32-characters
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
